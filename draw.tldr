						},
						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							},
							"content": [
								{
									"type": "text",
									"marks": [
										{
											"type": "code"
										}
									],
									"text": "──────────────────────────────  Real Estate Company  ↑ 423% Qualified Leads  ↓ 38% Cost Per Lead  3.8x ROAS  Generated ₹1.8Cr Pipeline  [View Case Study →]  ──────────────────────────────"
