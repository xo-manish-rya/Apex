							},
							"content": [
								{
									"type": "text",
									"text": "1. Featured Results (Most Important)"
								}
							]
						},
						{
							"type": "paragraph",
							"attrs": {
								"dir": "auto"
							},
							"content": [
								{
									"type": "text",
									"text": "This section should make people stop scrolling."
